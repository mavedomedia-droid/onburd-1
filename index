    Powered by <a href="https://onburd.com/ng" target="_blank" rel="noopener" data-track="more_routes">onburd.com/ng</a>
    <span class="sep">·</span>
    Pay Small Small™
  </p>
</main>

<!-- ============ LEAD MODAL — flight booking style ============ -->
<div class="modal-backdrop" id="modal" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
  <div class="modal">
    <div class="modal-grip"></div>
    <button class="modal-close" id="modalClose" aria-label="Close">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
    </button>

    <div id="modalForm">
      <p class="modal-eyebrow"><span class="bar"></span>Pay Small Small request</p>
      <h3 id="modalTitle">Where are you <em>flying?</em></h3>
      <p class="lead">Tell us your route and we'll come back with the fare and your installment plan.</p>

      <form id="leadForm" novalidate>

        <!-- Flight booking widget — From | Swap | To, then date below -->
        <div class="booking-widget">
          <div class="from-to">
            <div class="ft-cell from">
              <label class="ft-label" for="lf-from">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M2.5 19h19v2h-19v-2zm19.07-9.94c-.21-.8-1.04-1.28-1.84-1.06L14.92 9.4 8.46 3.4l-1.93.51 3.88 6.71-4.55 1.22-1.81-1.41-1.45.39 2.07 3.59.81 1.39 1.69-.45 5.32-1.43 4.36-1.17 5.65-1.51c.81-.23 1.28-1.05 1.07-1.85z"/></svg>
                From
              </label>
              <select id="lf-from" name="from" class="ft-select" required>
                <option value="Lagos">Lagos (LOS)</option>
                <option value="Abuja">Abuja (ABV)</option>
              </select>
            </div>

            <div class="ft-swap" aria-hidden="true">
              <div class="ft-swap-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M7 4 4 7l3 3M4 7h16M17 14l3 3-3 3M20 17H4"/>
                </svg>
              </div>
            </div>

            <div class="ft-cell to">
              <label class="ft-label" for="lf-to">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M21 16v-2l-8-5V3.5C13 2.67 12.33 2 11.5 2S10 2.67 10 3.5V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L13 19v-5.5l8 2.5z"/></svg>
                To
              </label>
              <input type="text" id="lf-to" name="to" class="ft-input" placeholder="e.g. Dubai, New York" required autocomplete="off" />
            </div>
          </div>

          <div class="booking-date">
            <label class="ft-label" for="lf-when">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
              Travel date
            </label>
            <input type="text" id="lf-when" name="when" placeholder="e.g. December 2025" autocomplete="off" />
          </div>
        </div>

        <!-- Contact fields -->
        <div class="contact-fields">
          <div class="field-label">Your details</div>
          <input type="text" id="lf-name" name="name" placeholder="Full name" required autocomplete="name" />
          <div class="contact-row">
            <input type="tel" id="lf-phone" name="phone" placeholder="Phone number" required autocomplete="tel" inputmode="tel" />
            <input type="email" id="lf-email" name="email" placeholder="Email (optional)" autocomplete="email" />
          </div>
        </div>

        <button type="submit" class="submit">
          Request my Pay Small Small plan
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </button>

        <p class="modal-fineprint">By submitting, you agree to be contacted by the onburd team about your route.</p>
      </form>
    </div>

    <div class="modal-success" id="modalSuccess">
      <div class="success-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
      </div>
      <h3>Got it. We'll be in <em>touch</em>.</h3>
      <p class="lead">Your route request is in. Our team will reach out shortly with your fare and Pay Small Small plan.</p>

      <hr class="success-divider" />

      <a href="https://onburd.com/ng" class="submit secondary" id="successOnburdLink" target="_blank" rel="noopener" data-track="success_onburd_click">
        See more on onburd
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
      <p class="modal-fineprint">Flights · Hotels · Events · Cinema · Travel Card — <a href="https://onburd.com/ng" target="_blank" rel="noopener" style="color:var(--blue);text-decoration:none;font-weight:600;">onburd.com/ng</a></p>
    </div>
  </div>
</div>

<script>
const WA_NUMBER = "2348179794423";
const WA_MESSAGES = {
  play_button:    "Hi onburd! I want to press play 🟢 — let's book a flight with Pay Small Small.",
  track_los_lhr:  "Hi onburd! I want to lock the Lagos → London (LOS-LHR) fare with 10% down (₦180,863).",
  track_abv_can:  "Hi onburd! I want to lock the Abuja → Guangzhou (ABV-CAN) fare with 10% down (₦256,777).",
  track_los_nbo:  "Hi onburd! I want to lock the Lagos → Nairobi (LOS-NBO) fare with 10% down (₦271,418).",
};
const WA_DEFAULT = "Hi onburd! I'd like to book a flight with Pay Small Small.";

function track(eventName, params = {}) {
  window.dataLayer = window.dataLayer || [];
  window.dataLayer.push({ event: eventName, ...params });
  if (typeof window.fbq === "function") {
    if (eventName === "whatsapp_click")    window.fbq("track", "Contact", params);
    else if (eventName === "lead_submit")  window.fbq("track", "Lead", params);
    else                                   window.fbq("trackCustom", eventName, params);
  }
  if (typeof window.gtag === "function") window.gtag("event", eventName, params);
  console.log("[track]", eventName, params);
}

function buildWa(message) {
  return `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(message)}`;
}

// Play button + 3 route cards still go to WhatsApp (top-of-page hot-leads)
document.querySelectorAll('[data-track="whatsapp"]').forEach((el) => {
  el.addEventListener("click", (e) => {
    e.preventDefault();
    const source = el.dataset.source || "unknown";
    const msg = WA_MESSAGES[source] || WA_DEFAULT;
    track("whatsapp_click", { source });
    window.open(buildWa(msg), "_blank", "noopener");
  });
});
document.querySelectorAll('[data-track="more_routes"]').forEach((el) => {
  el.addEventListener("click", () => track("more_routes_click", { destination: el.href }));
});
document.querySelectorAll('[data-track="logo"]').forEach((el) => {
  el.addEventListener("click", () => track("logo_click"));
});
document.querySelectorAll('[data-track="success_onburd_click"]').forEach((el) => {
  el.addEventListener("click", () => track("success_onburd_click"));
});

// MODAL — lead capture (NO WhatsApp handoff in modal flow)
const modal       = document.getElementById("modal");
const openBtn     = document.getElementById("openModal");
const closeBtn    = document.getElementById("modalClose");
const modalForm   = document.getElementById("modalForm");
const modalSuccess= document.getElementById("modalSuccess");
const leadForm    = document.getElementById("leadForm");

function openModal(trigger) {
  modal.classList.add("open");
  modalForm.style.display = "block";
  modalSuccess.classList.remove("show");
  leadForm.reset();
  track("modal_shown", { trigger });
  setTimeout(() => document.getElementById("lf-to").focus(), 200);
}
function closeModal() {
  modal.classList.remove("open");
  track("modal_dismissed");
}
openBtn.addEventListener("click", () => {
  track("other_routes_click");
  openModal("other_routes_bar");
});
closeBtn.addEventListener("click", closeModal);
modal.addEventListener("click", (e) => { if (e.target === modal) closeModal(); });
document.addEventListener("keydown", (e) => {
  if (e.key === "Escape" && modal.classList.contains("open")) closeModal();
});

leadForm.addEventListener("submit", (e) => {
  e.preventDefault();
  const data = {
    name:  document.getElementById("lf-name").value.trim(),
    phone: document.getElementById("lf-phone").value.trim(),
    email: document.getElementById("lf-email").value.trim(),
    when:  document.getElementById("lf-when").value.trim(),
    from:  document.getElementById("lf-from").value.trim(),
    to:    document.getElementById("lf-to").value.trim(),
  };
  if (!data.name || !data.phone || !data.from || !data.to) {
    alert("Please fill in your name, phone, and the flight route.");
    return;
  }

  // Fire lead event — this is the conversion
  track("lead_submit", {
    source: "other_routes_modal",
    route_from: data.from,
    route_to: data.to,
    has_date: data.when ? 1 : 0,
    has_email: data.email ? 1 : 0,
  });

  // === BACKEND HOOK (GAS endpoint goes here later) ===
  // fetch('YOUR_GAS_URL', {
  //   method: 'POST',
  //   headers: { 'Content-Type': 'text/plain' },
  //   body: JSON.stringify({ action: 'leadSubmit', ...data })
  // });

  // Show success — leads to onburd.com/ng
  modalForm.style.display = "none";
  modalSuccess.classList.add("show");
});

track("landing_page_view", { page: "onburd_pss_album_v8" });
</script>

</body>
</html>
