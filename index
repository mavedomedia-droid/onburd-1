<style>
  :root {
    --blue:        #1E3FCC;
    --blue-deep:   #0F1E66;
    --blue-soft:   #3B5BFF;
    --blue-tint:   #EEF1FF;
    --blue-tint-2: #DDE4FF;

    --blue-light:   #4F6FE6;
    --blue-light-2: #6B89F0;

    --green:       #A8C926;
    --green-bright:#C8EE3A;
    --green-deep:  #5E7A12;

    /* WHITE base — page is now clean white, not cream */
    --bg:          #FFFFFF;
    --surface:     #FFFFFF;
    --surface-2:   #F7F8FB;       /* very subtle off-white for hover/strip */
    --paper:       #FFFFFF;
    --ink:         #0E1530;
    --ink-2:       #2A3358;
    --ink-3:       #5A6489;
    --line:        #E6E8EE;
    --line-2:      #F0F2F6;

    --orange:      #FF8E63;
    --pink:        #FFB37C;

    --font-display: "Bricolage Grotesque", ui-sans-serif, system-ui, sans-serif;
    --font-serif:   "Instrument Serif", "Times New Roman", serif;
    --font-body:    "Inter Tight", ui-sans-serif, system-ui, sans-serif;
  }

  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }

  body {
    font-family: var(--font-body);
    background: var(--bg);
    color: var(--ink);
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    min-height: 100vh;
    min-height: 100dvh;
    position: relative;
    overflow-x: hidden;
  }

  /* very subtle ambient — kept light, no warm/orange */
  body::before {
    content: "";
    position: fixed; inset: 0;
    background:
      radial-gradient(900px 500px at 8% 0%, rgba(30,63,204,0.05), transparent 60%),
      radial-gradient(700px 400px at 95% 100%, rgba(168,201,38,0.07), transparent 60%);
    pointer-events: none;
    z-index: 0;
  }
  body::after {
    content: "ONBURD";
    position: fixed;
    bottom: -3vw;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 32vw;
    line-height: 0.8;
    letter-spacing: -0.04em;
    color: var(--blue);
    opacity: 0.025;
    pointer-events: none;
    z-index: 0;
    white-space: nowrap;
  }
  @media (max-width: 768px) { body::after { display: none; } }

  /* ===== editorial side rails (desktop only) ===== */
  .rail {
    position: fixed;
    top: 50%;
    transform: translateY(-50%) rotate(-90deg);
    transform-origin: center;
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--ink-3);
    z-index: 2;
    pointer-events: none;
    white-space: nowrap;
  }
  .rail.left  { left: 8px; }
  .rail.right { right: 8px; }
  .rail b { color: var(--blue); font-weight: 700; }
  @media (max-width: 900px) { .rail { display: none; } }

  /* ===== STAGE ===== */
  .stage {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 460px;
    margin: 0 auto;
    padding: 14px 4px 40px;
    display: flex;
    flex-direction: column;
  }

  /* ===== TOP BAR ===== */
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 22px 8px;
  }
  .logo { display: inline-flex; }
  .logo svg { display: block; }
  .topbar-meta {
    font-family: var(--font-body);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-3);
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .topbar-meta::before {
    content: "";
    width: 6px; height: 6px;
    border-radius: 999px;
    background: var(--blue);
  }

  /* ===== ALBUM HEADER ===== */
  .album-head {
    padding: 16px 22px 18px;
    display: grid;
    grid-template-columns: 132px 1fr;
    gap: 18px;
    align-items: end;
    position: relative;
  }

  .cover-wrap {
    position: relative;
    width: 132px;
    height: 132px;
  }
  .cover {
    width: 100%; height: 100%;
    border-radius: 12px;
    overflow: hidden;
    box-shadow:
      0 12px 24px -10px rgba(30,63,204,0.32),
      0 0 0 1px rgba(15,30,102,0.08);
    background: linear-gradient(160deg, #FFB37C 0%, #FF8E63 35%, #5BC2D9 75%, #2E5F8A 100%);
    transition: transform 0.4s cubic-bezier(0.2, 0.9, 0.3, 1);
    position: relative;
  }
  .cover-wrap:hover .cover { transform: scale(1.02); }
  .cover svg { display: block; width: 100%; height: 100%; }

  .album-text {
    min-width: 0;
    padding-bottom: 4px;
  }
  .album-tag {
    font-family: var(--font-body);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--blue);
    font-weight: 700;
    margin-bottom: 10px;
  }

  .album-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(24px, 6.4vw, 28px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin: 0 0 8px;
  }
  .album-title .accent {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    color: var(--green-deep);
    font-size: 1.06em;
  }

  .album-sub {
    font-size: 12px;
    color: var(--ink-3);
    line-height: 1.4;
    display: flex;
    align-items: center;
    gap: 7px;
    flex-wrap: wrap;
  }
  .album-sub .b { color: var(--ink); font-weight: 700; }
  .album-sub .dot {
    width: 3px; height: 3px;
    border-radius: 999px;
    background: var(--ink-3);
    opacity: 0.4;
  }

  /* ===== SUBTLE "WHAT ONBURD DOES" STRIP ===== */
  /* light, scannable — quietly tells visitors that onburd is more than just flights */
  .what-strip {
    margin: 4px 14px 18px;
    padding: 12px 8px;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 4px;
  }
  .what-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    text-align: center;
    color: var(--ink-3);
    transition: color 0.15s ease;
  }
  .what-item.featured { color: var(--blue); }
  .what-item:hover { color: var(--blue); }
  .what-icon {
    width: 28px;
    height: 28px;
    display: grid;
    place-items: center;
    color: currentColor;
  }
  .what-icon svg { width: 22px; height: 22px; }
  .what-label {
    font-family: var(--font-body);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.04em;
    line-height: 1;
  }

  /* ===== ACTIONS ROW ===== */
  .actions {
    padding: 4px 22px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
  }
  .actions-meta {
    font-family: var(--font-body);
    font-size: 11px;
    color: var(--ink-3);
    line-height: 1.45;
  }
  .actions-meta .big {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 15px;
    color: var(--ink);
    display: block;
    margin-bottom: 2px;
    letter-spacing: -0.01em;
  }
  .actions-meta .big em {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    color: var(--green-deep);
    font-size: 1.05em;
  }

  .play {
    width: 60px;
    height: 60px;
    border-radius: 999px;
    background: var(--green);
    color: #0A1A00;
    display: grid;
    place-items: center;
    border: none;
    cursor: pointer;
    text-decoration: none;
    box-shadow: 0 0 0 0 rgba(168,201,38,0.5), 0 8px 20px -6px rgba(168,201,38,0.55);
    animation: pulseRing 2.4s ease-out infinite;
    transition: transform 0.18s ease, background 0.15s ease;
    flex-shrink: 0;
    position: relative;
  }
  .play:hover { transform: scale(1.06); background: var(--green-bright); }
  .play:active { transform: scale(0.96); }
  .play svg { width: 26px; height: 26px; margin-left: 3px; }
  @keyframes pulseRing {
    0%   { box-shadow: 0 0 0 0 rgba(168,201,38,0.5), 0 8px 20px -6px rgba(168,201,38,0.55); }
    70%  { box-shadow: 0 0 0 16px rgba(168,201,38,0), 0 8px 20px -6px rgba(168,201,38,0.4); }
    100% { box-shadow: 0 0 0 0 rgba(168,201,38,0), 0 8px 20px -6px rgba(168,201,38,0.4); }
  }

  /* ===== TRACKLIST HEADER ===== */
  .tracklist-head {
    display: grid;
    grid-template-columns: 22px 1fr auto;
    gap: 12px;
    padding: 0 28px 6px;
    align-items: center;
    font-family: var(--font-body);
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-3);
    font-weight: 600;
    border-bottom: 0.5px solid var(--line);
    margin: 0 6px 6px;
  }
  .tracklist-head span:nth-child(1) { text-align: center; }
  .tracklist-head span:nth-child(3) { text-align: right; }

  /* ===== TRACKS ===== */
  .tracks {
    list-style: none;
    margin: 0;
    padding: 4px 14px 10px;
  }
  .track {
    display: grid;
    grid-template-columns: 22px 1fr auto;
    gap: 12px;
    align-items: center;
    padding: 10px 10px;
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s ease, transform 0.15s ease;
    cursor: pointer;
    border: none;
    background: transparent;
    width: 100%;
    text-align: left;
    font-family: inherit;
    position: relative;
  }
  .track:hover { background: var(--surface-2); }
  .track:hover .track-num .n { display: none; }
  .track:hover .track-num .play-icon { display: block; }
  .track:hover .track-title { color: var(--blue); }

  .track.is-playing { background: var(--blue-tint); }
  .track.is-playing .track-title { color: var(--blue); }
  .track.is-playing .track-num .n { display: none; }
  .track.is-playing .track-num .eq { display: inline-flex; }

  .track-num {
    font-size: 13px;
    color: var(--ink-3);
    font-variant-numeric: tabular-nums;
    text-align: center;
    font-weight: 600;
    position: relative;
  }
  .track-num .play-icon { display: none; }
  .track-num .play-icon svg { width: 12px; height: 12px; vertical-align: middle; color: var(--blue); }
  .track-num .eq {
    display: none;
    align-items: flex-end;
    justify-content: center;
    gap: 1.5px;
    height: 14px;
    width: 100%;
  }
  .track-num .eq span {
    display: block;
    width: 2.5px;
    background: var(--blue);
    border-radius: 1px;
    animation: eq 0.9s ease-in-out infinite;
  }
  .track-num .eq span:nth-child(1) { animation-delay: -0.3s; height: 60%; }
  .track-num .eq span:nth-child(2) { animation-delay: -0.6s; height: 90%; }
  .track-num .eq span:nth-child(3) { animation-delay: -0.1s; height: 50%; }
  @keyframes eq {
    0%, 100% { transform: scaleY(0.4); }
    50%      { transform: scaleY(1); }
  }

  .track-info { min-width: 0; }
  .track-title {
    font-size: 14px;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.2;
    margin: 0 0 3px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.15s ease;
    letter-spacing: -0.005em;
  }
  .track-sub {
    font-size: 11px;
    color: var(--ink-3);
    display: flex;
    align-items: center;
    gap: 7px;
    line-height: 1.3;
  }
  .track-sub .strike {
    text-decoration: line-through;
    text-decoration-color: rgba(15,30,102,0.35);
    color: var(--ink-3);
  }
  .track-sub .dot {
    width: 3px; height: 3px;
    border-radius: 999px;
    background: var(--ink-3);
    opacity: 0.4;
  }
  .track-sub .small-small {
    color: var(--green-deep);
    font-weight: 700;
    font-style: italic;
    font-family: var(--font-serif);
    font-size: 12px;
  }

  /* === HIGHLIGHTED PRICE PILL === */
  .price-pill {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-end;
    background: var(--blue-light);
    color: #fff;
    padding: 8px 12px;
    border-radius: 10px;
    box-shadow: 0 4px 12px -4px rgba(79,111,230,0.4);
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
    flex-shrink: 0;
    font-family: var(--font-display);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }
  .track:hover .price-pill {
    background: var(--blue);
    transform: translateY(-1px);
    box-shadow: 0 6px 16px -4px rgba(30,63,204,0.45);
  }
  .price-pill .label {
    font-family: var(--font-body);
    font-size: 8px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--green-bright);
    font-weight: 700;
    margin-bottom: 3px;
  }
  .price-pill .amount {
    font-weight: 800;
    font-size: 15px;
    letter-spacing: -0.01em;
  }

  /* ===== OTHER ROUTES BAR ===== */
  .other-routes-wrap {
    position: relative;
    padding: 18px 14px 0;
    margin: 0 0 14px;
  }
  .other-routes {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 14px 16px 14px 78px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 12px;
    align-items: center;
    color: var(--ink);
    text-decoration: none;
    cursor: pointer;
    font-family: inherit;
    width: 100%;
    text-align: left;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
    position: relative;
    border-style: solid;
  }
  .other-routes:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 24px -8px rgba(79,111,230,0.22);
    border-color: rgba(79,111,230,0.3);
  }
  .plane-icon {
    position: absolute;
    left: 22px;
    top: 50%;
    transform: translateY(-50%) rotate(-18deg);
    width: 56px;
    height: 56px;
    background: var(--blue-light);
    border-radius: 14px;
    display: grid;
    place-items: center;
    color: var(--green-bright);
    box-shadow: 0 8px 18px -4px rgba(79,111,230,0.45);
    z-index: 2;
    transition: transform 0.25s ease, background 0.2s ease;
  }
  .other-routes:hover .plane-icon {
    transform: translateY(-50%) rotate(-8deg) scale(1.06);
    background: var(--blue);
  }
  .plane-icon svg {
    width: 28px;
    height: 28px;
    transform: rotate(18deg);
  }

  .or-text { min-width: 0; }
  .or-title {
    font-family: var(--font-display);
    font-size: 13.5px;
    font-weight: 700;
    line-height: 1.25;
    margin: 0 0 2px;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .or-title em {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    color: var(--green-deep);
    font-size: 1.05em;
  }
  .or-sub {
    font-size: 11px;
    color: var(--ink-3);
    line-height: 1.3;
    font-weight: 500;
  }
  .or-cta {
    width: 30px; height: 30px;
    border-radius: 999px;
    background: var(--blue-tint);
    color: var(--blue-light);
    display: grid; place-items: center;
    flex-shrink: 0;
    transition: transform 0.15s ease, background 0.15s ease, color 0.15s ease;
  }
  .other-routes:hover .or-cta {
    transform: translateX(3px);
    background: var(--blue-light);
    color: #fff;
  }
  .or-cta svg { width: 13px; height: 13px; }

  /* ===== FOOTNOTE ===== */
  .footnote {
    text-align: center;
    font-size: 10px;
    color: var(--ink-3);
    padding: 0 18px 18px;
    letter-spacing: 0.04em;
    font-family: var(--font-body);
  }
  .footnote a { color: var(--blue); text-decoration: none; font-weight: 600; }
  .footnote a:hover { text-decoration: underline; }
  .footnote .sep { opacity: 0.4; margin: 0 6px; }

  /* ===== MODAL — flight booking style ===== */
  .modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(15,30,102,0.55);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 100;
    display: none;
    align-items: flex-end;
    justify-content: center;
    animation: fadeIn 0.22s ease;
  }
  @media (min-width: 600px) { .modal-backdrop { align-items: center; padding: 20px; } }
  .modal-backdrop.open { display: flex; }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

  .modal {
    background: #fff;
    border-radius: 22px 22px 0 0;
    padding: 26px 22px 22px;
    max-width: 480px;
    width: 100%;
    position: relative;
    box-shadow: 0 -24px 60px -10px rgba(15,30,102,0.3);
    animation: slideUp 0.32s cubic-bezier(0.2, 0.9, 0.3, 1);
    max-height: 92vh;
    overflow-y: auto;
  }
  @media (min-width: 600px) { .modal { border-radius: 22px; } }
  @keyframes slideUp { from { transform: translateY(60px); opacity: 0.4; } to { transform: translateY(0); opacity: 1; } }

  .modal-grip {
    width: 44px; height: 4px;
    background: var(--line);
    border-radius: 999px;
    margin: -10px auto 16px;
  }
  @media (min-width: 600px) { .modal-grip { display: none; } }

  .modal-close {
    position: absolute;
    top: 16px; right: 16px;
    background: var(--surface-2);
    border: none;
    color: var(--ink-2);
    cursor: pointer;
    width: 32px; height: 32px;
    border-radius: 999px;
    display: grid; place-items: center;
    transition: background 0.15s ease;
  }
  .modal-close:hover { background: var(--line); color: var(--ink); }

  .modal-eyebrow {
    font-family: var(--font-body);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--blue);
    font-weight: 700;
    margin: 0 0 8px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .modal-eyebrow .bar {
    width: 24px; height: 1px;
    background: var(--blue-tint-2);
  }

  .modal h3 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 24px;
    line-height: 1.1;
    margin: 0 0 6px;
    color: var(--ink);
    letter-spacing: -0.025em;
    padding-right: 30px;
  }
  .modal h3 em {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    color: var(--green-deep);
    font-size: 1.05em;
  }
  .modal p.lead {
    color: var(--ink-3);
    font-size: 12.5px;
    margin: 0 0 18px;
    line-height: 1.5;
  }

  /* === FLIGHT BOOKING WIDGET — joined From/To box, like Skyscanner/Wakanow === */
  .booking-widget {
    border: 1px solid var(--line);
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 12px;
    background: #fff;
    transition: border-color 0.18s ease;
  }
  .booking-widget:focus-within {
    border-color: var(--blue);
    box-shadow: 0 0 0 3px rgba(30,63,204,0.10);
  }

  /* From/To row — left and right sit in one box separated by a vertical line + swap arrow */
  .from-to {
    display: grid;
    grid-template-columns: 1fr 36px 1fr;
    align-items: center;
    border-bottom: 1px solid var(--line);
    position: relative;
  }
  .ft-cell {
    padding: 12px 14px;
    min-width: 0;
  }
  .ft-cell.from { border-right: 0; }
  .ft-cell .ft-label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 9px;
    font-weight: 700;
    color: var(--ink-3);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .ft-cell .ft-label svg { width: 11px; height: 11px; color: var(--blue); }
  .ft-cell .ft-input,
  .ft-cell .ft-select {
    width: 100%;
    border: none;
    background: transparent;
    font-family: inherit;
    font-size: 16px;
    font-weight: 700;
    color: var(--ink);
    padding: 0;
    -webkit-appearance: none;
    appearance: none;
    letter-spacing: -0.01em;
  }
  .ft-cell .ft-input:focus,
  .ft-cell .ft-select:focus {
    outline: none;
  }
  .ft-cell .ft-input::placeholder { color: #B0B6CC; font-weight: 600; }
  .ft-cell .ft-select {
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%235A6489' stroke-width='2.5' stroke-linecap='round'><path d='M6 9l6 6 6-6'/></svg>");
    background-repeat: no-repeat;
    background-position: right 0 center;
    background-size: 12px;
    padding-right: 16px;
  }

  /* swap arrow in middle */
  .ft-swap {
    width: 36px;
    height: 100%;
    min-height: 56px;
    display: grid;
    place-items: center;
    color: var(--blue);
    background: #fff;
    position: relative;
  }
  .ft-swap::before,
  .ft-swap::after {
    content: "";
    position: absolute;
    top: 0; bottom: 0;
    width: 1px;
    background: var(--line);
  }
  .ft-swap::before { left: 0; }
  .ft-swap::after  { right: 0; }
  .ft-swap-icon {
    width: 28px; height: 28px;
    border-radius: 999px;
    background: var(--blue-tint);
    color: var(--blue);
    display: grid; place-items: center;
    z-index: 2;
  }
  .ft-swap-icon svg { width: 12px; height: 12px; }

  /* date row */
  .booking-date {
    padding: 12px 14px;
  }
  .booking-date .ft-label {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-body);
    font-size: 9px;
    font-weight: 700;
    color: var(--ink-3);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }
  .booking-date .ft-label svg { width: 11px; height: 11px; color: var(--blue); }
  .booking-date input {
    width: 100%;
    border: none;
    background: transparent;
    font-family: inherit;
    font-size: 16px;
    font-weight: 700;
    color: var(--ink);
    padding: 0;
    letter-spacing: -0.01em;
  }
  .booking-date input:focus { outline: none; }
  .booking-date input::placeholder { color: #B0B6CC; font-weight: 600; }

  /* contact fields below the booking widget */
  .contact-fields {
    display: grid;
    gap: 10px;
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px dashed var(--line);
  }
  .contact-fields .field-label {
    font-family: var(--font-body);
    font-size: 9px;
    font-weight: 700;
    color: var(--ink-3);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: -4px;
  }
  .contact-fields input {
    width: 100%;
    padding: 11px 14px;
    border-radius: 10px;
    border: 1px solid var(--line);
    background: #fff;
    font-family: inherit;
    font-size: 14px;
    color: var(--ink);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .contact-fields input:focus {
    outline: none;
    border-color: var(--blue);
    box-shadow: 0 0 0 3px rgba(30,63,204,0.14);
  }
  .contact-fields input::placeholder { color: #A8AFC9; }
  .contact-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  @media (max-width: 380px) { .contact-row { grid-template-columns: 1fr; } }

  /* primary modal submit — stays green so it matches the play button identity */
  .submit {
    margin-top: 14px;
    width: 100%;
    padding: 15px 18px;
    border-radius: 12px;
    background: var(--green);
    color: #0A1A00;
    border: none;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 15px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    transition: background 0.15s ease, transform 0.1s ease;
    letter-spacing: -0.005em;
    text-decoration: none;
  }
  .submit:hover { background: var(--green-bright); }
  .submit:active { transform: translateY(1px); }
  .submit svg { width: 16px; height: 16px; }

  /* secondary submit — used as success "See more on onburd" */
  .submit.secondary {
    background: var(--blue);
    color: #fff;
  }
  .submit.secondary:hover { background: var(--blue-deep); }

  .modal-fineprint {
    font-size: 10px;
    color: var(--ink-3);
    text-align: center;
    margin: 12px 0 0;
    line-height: 1.5;
  }

  .modal-success { display: none; text-align: center; padding: 16px 8px 6px; }
  .modal-success.show { display: block; }
  .success-icon {
    width: 64px; height: 64px; border-radius: 999px;
    background: var(--green);
    margin: 0 auto 18px;
    display: grid; place-items: center;
    color: #0A1A00;
    animation: pop 0.4s cubic-bezier(0.2, 0.9, 0.3, 1.4);
  }
  @keyframes pop {
    0%   { transform: scale(0); }
    100% { transform: scale(1); }
  }
  .success-icon svg { width: 32px; height: 32px; }
  .modal-success h3 { padding-right: 0; }
  .success-divider {
    border: none;
    border-top: 1px dashed var(--line);
    margin: 22px 0 18px;
  }

  /* ===== INTRO REVEAL ===== */
  .reveal { opacity: 0; transform: translateY(8px); animation: reveal 0.6s cubic-bezier(0.2,0.9,0.3,1) forwards; }
  .reveal.d1 { animation-delay: 0.05s; }
  .reveal.d2 { animation-delay: 0.15s; }
  .reveal.d3 { animation-delay: 0.25s; }
  .reveal.d4 { animation-delay: 0.35s; }
  .reveal.d5 { animation-delay: 0.45s; }
  @keyframes reveal { to { opacity: 1; transform: translateY(0); } }
</style>
